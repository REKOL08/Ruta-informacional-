  <p style="margin-top:0.4rem;">Contacto: <a href="mailto:alabrada3@areandina.edu.co">alabrada3@areandina.edu.co</a> · Recursos disponibles en <a href="#">GitHub · REKOL08</a></p>
</footer>

<script>
// ─── QRs de las herramientas ───
window.addEventListener('load', function () {
  const qrs = [
    { id: 'qr-doaj', url: 'https://doaj.org' },
    { id: 'qr-publindex', url: 'https://scienti.minciencias.gov.co/publindex/' },
    { id: 'qr-scimago', url: 'https://www.scimagojr.com' },
    { id: 'qr-orcid', url: 'https://orcid.org/register' }
  ];
  qrs.forEach(({ id, url }) => {
    const el = document.getElementById(id);
    if (el && typeof QRCode !== 'undefined') {
      new QRCode(el, {
        text: url,
        width: 96,
        height: 96,
        colorDark: '#14324a',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.M
      });
    }
  });
});

// ─── Checklist interactivo ───
const checklist = [
  { t: 'Verifica una revista en DOAJ', d: 'Busca una revista de tu área y confirma que está listada.' },
  { t: 'Consulta la categoría en Publindex', d: 'Revisa la clasificación de una revista colombiana de tu campo.' },
  { t: 'Busca el cuartil en Scimago', d: 'Identifica el Q (Q1–Q4) de tu revista objetivo.' },
  { t: 'Pregunta por acuerdos transformativos', d: 'Consulta en Biblioteca si tu revista objetivo tiene APC cubierto.' },
  { t: 'Explora Papyrus', d: 'Ingresa con tu cuenta institucional y recorre la plataforma.' },
  { t: 'Crea o actualiza tu ORCID', d: 'Registra tu perfil y agrega tu afiliación a Areandina.' },
  { t: 'Ingresa al CRIS ADAGIO', d: 'Revisa tu producción registrada y explora los módulos de Ciencia Abierta.' }
];

const grid = document.getElementById('checkGrid');
let doneCount = 0;

checklist.forEach((item, i) => {
  const card = document.createElement('div');
  card.className = 'check-card';
  card.setAttribute('role', 'checkbox');
  card.setAttribute('aria-checked', 'false');
  card.setAttribute('tabindex', '0');
  card.innerHTML = `
    <div class="check-box"></div>
    <div class="check-text">
      <h4>${item.t}</h4>
      <p>${item.d}</p>
    </div>
  `;
  const toggle = () => {
    card.classList.toggle('done');
    const isDone = card.classList.contains('done');
    card.setAttribute('aria-checked', String(isDone));
    doneCount += isDone ? 1 : -1;
    const progress = document.getElementById('checkProgress');
    progress.textContent = doneCount === checklist.length
      ? '🎉 ¡Ruta completada! Ya eres un investigador abierto.'
      : `${doneCount} de ${checklist.length} completadas`;
  };
  card.addEventListener('click', toggle);
  card.addEventListener('keydown', e => {
    if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); toggle(); }
  });
  grid.appendChild(card);
});

// ─── Barra de progreso de scroll ───
window.addEventListener('scroll', () => {
  const docHeight = document.body.scrollHeight - window.innerHeight;
  const pct = docHeight > 0 ? (window.scrollY / docHeight) * 100 : 0;
  document.getElementById('progress').style.width = pct + '%';
});
</script>
